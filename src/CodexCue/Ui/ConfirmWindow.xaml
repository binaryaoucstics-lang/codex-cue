<Window x:Class="CodexCue.Ui.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" Height="258"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AutomationProperties.AutomationId="ConfirmWindow">
  <Grid Margin="16">
    <Border Background="White" CornerRadius="16" BorderBrush="#D6DEEA" BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Color="#52647C" />
      </Border.Effect>
      <Grid Margin="30,27,30,26">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="62" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="ConfirmTitle" FontFamily="{StaticResource ShellFont}" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
        <TextBlock x:Name="ConfirmBody" Grid.Row="1" Margin="0,10,0,0" FontFamily="{StaticResource ShellFont}" FontSize="16" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="KeepButton" MinWidth="118" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" AutomationProperties.AutomationId="KeepButton" Click="OnKeep" />
          <Button x:Name="DiscardButton" MinWidth="104" Style="{StaticResource PrimaryButtonStyle}" AutomationProperties.AutomationId="DiscardButton" Click="OnDiscard" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
